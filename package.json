{
	"name": "voice-appointment-agent",
	"version": "1.0.0",
	"description": "Twilio voice agent that manages dry cleaning orders and updates Notion in real-time",
	"main": "dist/server.js",
	"scripts": {
		"dev": "nodemon",
		"build": "tsc",
		"start": "node dist/server.js",
		"check": "tsc --noEmit",
		"dashboard": "tsx src/dashboard.ts"
	},
	"engines": {
		"node": ">=22.0.0",
		"npm": ">=10.9.2"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.96.0",
		"@google/genai": "^2.5.0",
		"@notionhq/client": "^5.21.0",
		"@notionhq/workers": ">=0.0.0",
		"@supabase/supabase-js": "^2.47.2",
		"alawmulaw": "^6.0.0",
		"body-parser": "^1.20.3",
		"cors": "^2.8.6",
		"dotenv": "^17.4.2",
		"express": "^4.21.2",
		"twilio": "^5.5.1",
		"ws": "^8.20.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^22.10.5",
		"@types/ws": "^8.18.1",
		"nodemon": "^3.1.7",
		"ts-node": "^10.9.2",
		"tsx": "^4.20.6",
		"typescript": "^5.7.3"
	}
